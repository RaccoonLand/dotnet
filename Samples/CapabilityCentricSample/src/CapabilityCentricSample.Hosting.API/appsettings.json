{
  "MessageLocalization": {
    "ConnectionString": "Data Source=localhost;Initial Catalog=CapabilityCentricSample;Integrated Security=True;MultipleActiveResultSets=True;Encrypt=False;TrustServerCertificate=True",
    "ServiceName": "RaccoonLandSamples",
    "ApplicationName": "CapabilityCentricSample",
    "DefaultCulture": "en-US",
    "RefreshInterval": "00:05:00",
    "AutoCreateTables": true,
    "AutoRegisterApplication": true,
    "AutoInsertMissingKeys": true
  },
  "ConnectionStrings": {
    "CommandConnection": "Data Source=localhost;Initial Catalog=CapabilityCentricSample;Integrated Security=True;MultipleActiveResultSets=True;Encrypt=False;TrustServerCertificate=True",
    "QueryConnection": "Data Source=localhost;Initial Catalog=CapabilityCentricSample;Integrated Security=True;MultipleActiveResultSets=True;Encrypt=False;TrustServerCertificate=True"
  },
  "FileStorage": {
    "MaxUploadBytes": 230686720,
    "AllowedContentTypes": [ "image/jpeg", "image/png", "image/webp", "application/pdf", "application/octet-stream", "video/mp4", "video/webm" ]
  },
  "FileStorage:FileSystem": {
    "RootPath": "App_Data/files"
  },
  "OpenApi": {
    "Enabled": true,
    "DocumentName": "v1",
    "Title": "Capability Centric Sample API",
    "Version": "v1",
    "Description": "Sample API demonstrating RaccoonLand capability-centric layout"
  },
  "HttpExecutionContext": {
    "UserIdClaim": "sub",
    "CorrelationIdHeader": "X-Correlation-Id"
  },
  "RequestCaching": {
    "Default": {
      "Duration": "00:05:00"
    },
    "Overrides": {
      "CapabilityCentricSample.People.Endpoints.Queries": {
        "Duration": "00:02:00"
      },
      "CapabilityCentricSample.People.Endpoints.Queries.GetPersonById": {
        "Duration": "00:00:30"
      },
      "CapabilityCentricSample.Departments.Endpoints.Queries": {
        "Duration": "00:03:00"
      }
    }
  },
  "Observability": {
    "Instrumentation": {
      "EnableTracing": false,
      "EnableMetrics": false,
      "EnableLogging": true
    }
  },
  "RaccoonLandSerilog": {
    "ApplicationName": "CapabilityCentricSample.Hosting.API",
    "EnrichWithApplicationName": true,
    "EnrichWithEnvironmentName": true,
    "EnrichWithMachineName": true,
    "EnrichWithTraceId": true
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
