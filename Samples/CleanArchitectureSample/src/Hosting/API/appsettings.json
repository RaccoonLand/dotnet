{
  "MessageLocalization": {
    "ConnectionString": "Data Source=localhost;Initial Catalog=CleanArchitectureSample;Integrated Security=True;MultipleActiveResultSets=True;Encrypt=False;TrustServerCertificate=True",
    "ServiceName": "RaccoonLandSamples",
    "ApplicationName": "CleanArchitectureSample",
    "DefaultCulture": "en-US",
    "RefreshInterval": "00:05:00",
    "AutoCreateTables": true,
    "AutoRegisterApplication": true,
    "AutoInsertMissingKeys": true
  },
  "ConnectionStrings": {
    "CommandConnection": "Data Source=localhost;Initial Catalog=CleanArchitectureSample;Integrated Security=True;MultipleActiveResultSets=True;Encrypt=False;TrustServerCertificate=True",
    "QueryConnection": "Data Source=localhost;Initial Catalog=CleanArchitectureSample;Integrated Security=True;MultipleActiveResultSets=True;Encrypt=False;TrustServerCertificate=True"
  },
  "FileStorage": {
    "MaxUploadBytes": 20971520,
    "AllowedContentTypes": [ "image/jpeg", "image/png", "image/webp", "application/pdf" ]
  },
  "FileStorage:FileSystem": {
    "RootPath": "App_Data/files"
  },
  "OpenApi": {
    "Enabled": true,
    "DocumentName": "v1",
    "Title": "Clean Architecture Sample API",
    "Version": "v1",
    "Description": "Sample demonstrating layered clean architecture"
  },
  "HttpExecutionContext": {
    "UserIdClaim": "sub",
    "CorrelationIdHeader": "X-Correlation-Id",
    "CorrelationIdHeaderMultiValueMode": "SingleValueOnly",
    "TenantIdHeaderMultiValueMode": "SingleValueOnly",
    "GenerateCorrelationIdWhenMissing": true,
    "EchoCorrelationIdInResponse": true
  },
  "RequestCaching": {
    "Default": {
      "Duration": "00:05:00"
    },
    "Overrides": {
      "CleanArchitectureSample.People.Endpoints.Queries": {
        "Duration": "00:02:00"
      },
      "CleanArchitectureSample.People.Endpoints.Queries.GetPersonById": {
        "Duration": "00:00:30"
      },
      "CleanArchitectureSample.Departments.Endpoints.Queries": {
        "Duration": "00:02:00"
      },
      "CleanArchitectureSample.Departments.Endpoints.Queries.GetDepartmentById": {
        "Duration": "00:00:30"
      }
    }
  },
  "OutboxEventStore": {
    "Schema": "dbo",
    "Table": "OutboxEvent"
  },
  "OutboxRelay": {
    "ClaimLease": "00:05:00",
    "BatchSize": 20,
    "PollInterval": "00:00:02",
    "ProcessDomainEvents": true,
    "ProcessServiceEvents": false
  },
  "Observability": {
    "Instrumentation": {
      "EnableTracing": false,
      "EnableMetrics": false,
      "EnableLogging": true,
      "RequestNameInMetrics": "FullName"
    }
  },
  "RaccoonLandSerilog": {
    "ApplicationName": "CleanArchitectureSample.Hosting.API",
    "EnrichWithApplicationName": true,
    "EnrichWithEnvironmentName": true,
    "EnrichWithMachineName": true,
    "EnrichWithTraceId": true
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
