<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <Description>RaccoonLand command-side SQL Server persistence: the base command DbContext that wraps SaveChanges in a transaction, an audit/concurrency SaveChanges interceptor driven by ICurrentExecutionContext (with a NullCurrentExecutionContext fallback), a transactional outbox interceptor that writes aggregate domain/service events, and the full IOutboxWriter implementation (writer, SQL Server channel options + registry, interceptor) that flushes enqueued outbox messages with Dapper on the same connection and transaction.</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Dapper" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.SqlServer" />
    <PackageReference Include="RaccoonLand.Core.Domain" />
    <PackageReference Include="RaccoonLand.Core.ExecutionContext.Abstractions" />
    <PackageReference Include="RaccoonLand.Modules.Persistence.Outbox.Abstraction" />
  </ItemGroup>

</Project>
