<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!-- Local development NuGet server (BaGet). Packages built from this repo are pushed here. -->
    <add key="raccoonland-local" value="https://localhost:5001/v3/index.json" />
  </packageSources>
  <!-- Resolve all RaccoonLand.* packages exclusively from the local feed so that
       same-versioned packages published elsewhere (e.g. nuget.org) never shadow them. -->
  <packageSourceMapping>
    <packageSource key="raccoonland-local">
      <package pattern="RaccoonLand.*" />
    </packageSource>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
